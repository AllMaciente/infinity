---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="404 - Página Não Encontrada">
  <div class="min-h-[80vh] flex items-center justify-center px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-20 left-10 w-64 h-64 bg-accent rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary rounded-full blur-3xl"></div>
    </div>
    
    <div class="text-center max-w-lg relative z-10">
      <div class="mb-6">
        <img 
          src="/favicon.svg" 
          alt="Infinity" 
          class="w-24 h-24 mx-auto mb-4 opacity-20"
        />
        <div class="relative inline-block">
          <span class="text-[12rem] sm:text-[16rem] leading-none font-display font-bold text-transparent bg-clip-text bg-gradient-to-br from-gray-200 to-gray-300 select-none">
            404
          </span>
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-accent rounded-full flex items-center justify-center text-2xl animate-bounce">
            ?
          </div>
        </div>
      </div>
      
      <h1 class="text-3xl sm:text-4xl font-display font-bold mb-4">
        Ops! Energia esgotada
      </h1>
      
      <p class="text-gray text-lg mb-8 max-w-md mx-auto">
        A página que você procura não foi encontrada. 
        Talvez tenha sido movida ou nunca existiu.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/" class="btn btn-primary text-lg px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Voltar ao Início
        </a>
        <a href="/loja" class="btn btn-outline text-lg px-8 py-4">
          Explorar Produtos
        </a>
      </div>
      
      <div class="mt-12 flex justify-center gap-8 text-sm text-gray-light">
        <a href="/loja" class="hover:text-accent transition-colors">Loja</a>
        <span class="text-gray-300">|</span>
        <a href="/modelo" class="hover:text-accent transition-colors">Modelos 3D</a>
        <span class="text-gray-300">|</span>
        <a href="#sobre" class="hover:text-accent transition-colors">Sobre</a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .text-\[12rem\] {
    font-size: clamp(6rem, 20vw, 12rem);
  }
  .text-\[16rem\] {
    font-size: clamp(8rem, 25vw, 16rem);
  }
</style>
