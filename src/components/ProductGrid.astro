---
import ProductCard from './ProductCard.astro';

interface Product {
  id: number;
  slug: string;
  name: string;
  shortDescription?: string;
  price: number;
  originalPrice?: number | null;
  image: string;
  category: string;
  stock: number;
  featured?: boolean;
}

interface Props {
  products: Product[];
  columns?: 1 | 2 | 3 | 4;
}

const { products, columns = 3 } = Astro.props;

const gridCols = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
};
---

{products.length === 0 ? (
  <div class="text-center py-16">
    <svg class="w-20 h-20 mx-auto text-gray-light mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <h3 class="font-display font-semibold text-xl mb-2">Nenhum produto encontrado</h3>
    <p class="text-gray mb-6">Tente ajustar seus filtros ou buscar por outros termos.</p>
    <a href="/loja" class="btn btn-primary">Ver todos os produtos</a>
  </div>
) : (
  <div class={`grid ${gridCols[columns]} gap-6`}>
    {products.map(product => (
      <ProductCard {...product} />
    ))}
  </div>
)}
