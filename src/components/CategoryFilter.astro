---
interface Category {
  slug: string;
  name: string;
  count: number;
}

interface Props {
  categories: Category[];
  activeCategory?: string;
}

const { categories, activeCategory } = Astro.props;

const allCategories = [
  { slug: 'todos', name: 'Todos os Produtos', count: categories.reduce((sum, c) => sum + c.count, 0) },
  ...categories
];
---

<div class="flex flex-wrap gap-2">
  {allCategories.map(category => (
    <a 
      href={category.slug === 'todos' ? '/loja' : `/loja?categoria=${category.slug}`}
      class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
        activeCategory === category.slug || (category.slug === 'todos' && !activeCategory)
          ? 'bg-primary text-white'
          : 'bg-gray-100 text-secondary hover:bg-gray-200'
      }`}
    >
      {category.name}
      <span class={`ml-1 text-xs ${activeCategory === category.slug || (category.slug === 'todos' && !activeCategory) ? 'opacity-75' : 'opacity-60'}`}>
        ({category.count})
      </span>
    </a>
  ))}
</div>
