---
interface Props {
  placeholder?: string;
  value?: string;
}

const { placeholder = "Buscar produtos...", value = "" } = Astro.props;
---

<div class="relative">
  <label for="search-input" class="sr-only">Buscar produtos</label>

  <div
    class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
  >
    <svg
      class="w-5 h-5 text-gray-light"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>

  <input
    type="search"
    id="search-input"
    name="search"
    placeholder={placeholder}
    value={value}
    class="input pl-12 pr-4 py-3 bg-white"
    autocomplete="off"
  />

  {
    value && (
      <button
        type="button"
        id="clear-search"
        class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-light hover:text-primary transition-colors"
        aria-label="Limpar busca"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    )
  }
</div>

<script>
  const searchInput = document.getElementById(
    "search-input",
  ) as HTMLInputElement;
  const clearBtn = document.getElementById("clear-search");

  let debounceTimer: ReturnType<typeof setTimeout>;

  searchInput?.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const query = searchInput.value.trim();

      const url = new URL(window.location.href);
      if (query) {
        url.searchParams.set("q", query);
      } else {
        url.searchParams.delete("q");
      }

      window.location.href = url.toString();
    }, 500);
  });

  clearBtn?.addEventListener("click", () => {
    const url = new URL(window.location.href);
    url.searchParams.delete("q");
    window.location.href = url.toString();
  });
</script>
